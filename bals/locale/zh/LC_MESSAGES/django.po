msgstr "创建课程 · BALS"

#: main_app/templates/main_app/url_input.html:1
msgid "Create a new course"
msgstr "创建新课程"

#: main_app/templates/main_app/url_input.html:1
msgid "Which video would you like to start with?"
msgstr "你想从哪个视频开始？"

#: main_app/templates/main_app/url_input.html:1
msgid ""
"Paste a YouTube URL. We will check it, fetch the transcript and open your "
"course workspace."
msgstr "粘贴 YouTube 链接，系统会检查视频、获取字幕，然后带你进入课程工作台。"

#: main_app/templates/main_app/url_input.html:1
msgid "Supports youtube.com, youtu.be, Shorts and URLs with parameters"
msgstr "支持 youtube.com、youtu.be、Shorts 和带参数的链接"

#: main_app/templates/main_app/url_input.html:1
msgid "Check and create course"
msgstr "检查并创建课程"

#: main_app/templates/main_app/url_input.html:1
