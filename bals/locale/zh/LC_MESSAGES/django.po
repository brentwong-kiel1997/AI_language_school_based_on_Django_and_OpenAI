msgstr "正在提交…"

#: main_app/templates/main_app/url_input.html:1
msgid "Before you begin"
msgstr "开始之前"

#: main_app/templates/main_app/url_input.html:1
msgid "What videos work best?"
msgstr "适合什么视频？"

#: main_app/templates/main_app/url_input.html:1
msgid "Under 10 minutes"
msgstr "10 分钟以内"

#: main_app/templates/main_app/url_input.html:1
msgid "News, interviews and educational videos work well"
msgstr "新闻、访谈和知识视频效果更好"

#: main_app/templates/main_app/url_input.html:1
msgid "Captions are preferred"
msgstr "优先使用 YouTube 字幕"

#: main_app/templates/main_app/url_input.html:1
msgid ""
"We use manual captions first, then automatic captions, and Seed ASR when no "
"captions are available."
msgstr ""
"优先使用人工字幕，其次使用自动字幕；没有字幕时通过 Seed ASR 进行语音识别。"

#: main_app/templates/main_app/url_input.html:1
msgid "Publicly accessible"
msgstr "公开可访问"

#: main_app/templates/main_app/url_input.html:1
msgid "No login, age or regional restrictions"
msgstr "不能有登录、年龄或地区限制"

