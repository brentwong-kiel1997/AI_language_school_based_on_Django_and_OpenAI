# Volcengine Ark + Seed ASR (standalone ark_cli / `ark`)
ARK_API_KEY=
ARK_MODEL=doubao-seed-2.0-lite
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
ARK_TIMEOUT_SECONDS=300
ARK_MAX_TOKENS=32768
# Used by Django Generator (lesson orchestration), not by ark_cli client itself:
ARK_MAX_RETRIES=2
ARK_VALIDATION_RETRIES=1
ARK_AGENT_PROMPT_CHARS=18000
ARK_AGENT_CHUNK_CHARS=6000
SEED_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/plan/sauc/bigmodel_nostream
SEED_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
SEED_ASR_SEGMENT_MS=200
# Extra processing/network allowance added to the WAV duration; also used for connect and initialization.
SEED_ASR_TIMEOUT_SECONDS=120

# MiniMax China Token Plan (standalone minimax_cli / mmx)
MINIMAX_API_KEY=
MINIMAX_REGION=cn
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_TEXT_MODEL=MiniMax-M3
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_SPEECH_MODEL=speech-2.8-hd
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3
MINIMAX_MUSIC_MODEL=music-2.6
MINIMAX_VISION_MODEL=MiniMax-VL
MINIMAX_CONTEXT_WINDOW_TOKENS=1000000
MINIMAX_MAX_TOKENS=131072
MINIMAX_TIMEOUT_SECONDS=120
MINIMAX_VIDEO_TIMEOUT_SECONDS=600
MINIMAX_POLL_INTERVAL_SECONDS=5
MINIMAX_OUTPUT_DIR=.
# MINIMAX_QUOTA_ENDPOINT=/v1/coding_plan/quota
# MINIMAX_SEARCH_ENDPOINT=/v1/coding_plan/search
# MINIMAX_VISION_ENDPOINT=/v1/coding_plan/vlm
# MINIMAX_CONFIG_DIR=~/.mmx
